{
    "id": "nl.emphisia.icon",
    "runtime": "org.gnome.Platform",
    "runtime-version": "49",
    "sdk": "org.gnome.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.rust-stable"
    ],
    "command": "Iconic",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--device=dri",
        "--socket=wayland"
    ],
    "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin",
        "env": {
            "RUST_LOG": "Iconic=info"
        }
    },
    "modules": [
        {
            "name": "Iconic",
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/youpie/Iconic/releases/download/v2026.4.1/Iconic-2026.4.1.tar.xz",
                    "sha256": "7f1377e34699f4cfe0e9369636d0e85b02db91063724c83a83e29b7c1eb720d0"
                }
            ]
        }
    ]
}